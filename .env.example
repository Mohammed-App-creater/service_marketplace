# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (psycopg3 / dj-database-url style)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/service_marketplace

# JWT lifetimes (minutes / days)
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=7

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Dev/testing: skip OTP verification — accounts can log in right after
# registering. Set to False before real launch!
AUTO_VERIFY_NEW_ACCOUNTS=True

# Localization
DEFAULT_LANGUAGE=en

# Stubbed integration providers (swap class paths to go live)
SMS_PROVIDER=apps.notifications.providers.stubs.ConsoleSMSProvider
PUSH_PROVIDER=apps.notifications.providers.stubs.ConsolePushProvider
REALTIME_PROVIDER=apps.notifications.providers.stubs.ConsoleRealtimeProvider
EMAIL_PROVIDER=apps.notifications.providers.stubs.ConsoleEmailProvider

# CORS (comma-separated origins; empty = none)
CORS_ALLOWED_ORIGINS=

# Celery (eager in MVP; broker unused while eager)
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# Booking policy
BOOKING_MIN_LEAD_MINUTES=15
BOOKING_SLOT_GRANULARITY_MINUTES=15
BOOKING_SERVICE_FEE_PERCENT=5
