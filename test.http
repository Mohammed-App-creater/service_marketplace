### Smart Service Marketplace — API smoke tests
### Works with the VS Code "REST Client" extension (humao.rest-client):
### click "Send Request" above any request.
### Switch @host between local and Render as needed.

@host = http://127.0.0.1:8000
# @host = https://<your-service>.onrender.com
@json = application/json

###############################################################
# 1. PHONE VALIDATOR CHECKS
###############################################################

### 1a. Valid — local 09 format → 201 (auto-normalized to +2519…)
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "0911223344",
  "password": "StrongPass123",
  "full_name": "Valid Nine"
}

### 1b. Valid — Safaricom 07 format → 201
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "+251712345678",
  "password": "StrongPass123",
  "full_name": "Valid Seven"
}

### 1c. Invalid — prefix 8 is not a mobile prefix → 400
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "+251811223344",
  "password": "StrongPass123",
  "full_name": "Bad Prefix"
}

### 1d. Invalid — too short → 400
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "+25191122334",
  "password": "StrongPass123",
  "full_name": "Too Short"
}

### 1e. Invalid — too long → 400
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "+2519112233445",
  "password": "StrongPass123",
  "full_name": "Too Long"
}

### 1f. Invalid — wrong country (US) → 400
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "phone": "+15551234567",
  "password": "StrongPass123",
  "full_name": "Wrong Country"
}

###############################################################
# 2. FULL AUTH FLOW
#    (OTP code: local → runserver console; Render → service Logs,
#     look for the "[STUB SMS] … verification code" line)
###############################################################

### 2a. Register with email
POST {{host}}/api/v1/auth/register/
Content-Type: {{json}}

{
  "email": "tester2@example.com",
  "password": "StrongPass123",
  "full_name": "Email Tester"
}

### 2b. Verify OTP (paste the code from the logs)
POST {{host}}/api/v1/auth/verify-otp/
Content-Type: {{json}}

{
  "identifier": "tester2@example.com",
  "code": "420363",
  "purpose": "email_verify"
}

### 2c. Login (identifier = email OR phone, any ET format)
# @name login
POST {{host}}/api/v1/auth/login/
Content-Type: {{json}}

{
  "identifier": "tester2@example.com",
  "password": "StrongPass123"
}

### 2d. Login with unverified account → 400 "Account not verified…"
POST {{host}}/api/v1/auth/login/
Content-Type: {{json}}

{
  "identifier": "0911223344",
  "password": "StrongPass123"
}

### 2e. My profile (uses the token from 2c automatically)
GET {{host}}/api/v1/me/
Authorization: Bearer {{login.response.body.access}}

### 2f. Refresh the access token
POST {{host}}/api/v1/auth/token/refresh/
Content-Type: {{json}}

{
  "refresh": "{{login.response.body.refresh}}"
}

###############################################################
# 3. QUICK PUBLIC READS (no auth needed)
###############################################################

### 3a. Top-level category pillars with children
GET {{host}}/api/v1/categories/?top=true

### 3b. Search vendors near Addis Ababa center, nearest first
GET {{host}}/api/v1/vendors/?lat=9.0108&lng=38.7613&order_by=distance

### 3c. Subscription plans
GET {{host}}/api/v1/subscription-plans/
